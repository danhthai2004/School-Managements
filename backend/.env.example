# =========================================================================
# BACKEND CORE CONFIGURATION
# =========================================================================
# Project specific configuration
JWT_SECRET=your_32_character_secret_here

# Initial Seed Data for System Admin (firstLogin=false)
SYSTEM_ADMIN_EMAIL=admin@example.com
SYSTEM_ADMIN_PASSWORD=YourSecurePassword123!

# =========================================================================
# DATABASE CONFIGURATION (Spring Boot)
# =========================================================================
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/neondb
SPRING_DATASOURCE_USERNAME=your_db_user
SPRING_DATASOURCE_PASSWORD=your_db_password

# =========================================================================
# AUTHENTICATION (Google OAuth)
# =========================================================================
GOOGLE_OAUTH_CLIENT_ID=your_google_id_token_verification_client_id.apps.googleusercontent.com

# =========================================================================
# EXTERNAL SERVICES (Mail & AI)
# =========================================================================
# Gmail SMTP
MAIL_USERNAME=your_gmail@gmail.com
MAIL_APP_PASSWORD=your_app_specific_password_here

# LLM & AI API Keys (OpenRouter, Gemini, etc.)
LLM_API_KEY=sk-or-v1-...
RISK_AI_API_KEY=sk-or-v1-...

# =========================================================================
# CORS SETTINGS
# =========================================================================
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
